PORT=4000
DEBUG=nodejs-api-authentication*
LOG_FOLDER=./logs
LOG_FILE=combined.log
# REQUIRED: Must be at least 32 random characters. Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_use_a_random_string_of_32_or_more_characters

# Rate limiting: max login attempts per 1 minute per IP (default: 5)
LOGIN_RATE_LIMIT=5

# Rate limiting: max registration attempts per 1 hour per IP (default: 10)
REGISTER_RATE_LIMIT=10

# Rate limiting: max forgot-password requests per 1 hour per IP (default: 5)
FORGOT_PASSWORD_RATE_LIMIT=5

# Rate limiting: max reset-password attempts per 1 hour per IP (default: 10)
RESET_PASSWORD_RATE_LIMIT=10

# Rate limiting: max confirm-email attempts per 1 hour per IP (default: 10)
CONFIRM_EMAIL_RATE_LIMIT=10

# Rate limiting: max resend-confirmation requests per 1 hour per IP (default: 5)
RESEND_CONFIRMATION_RATE_LIMIT=5

# Rate limiting: max token refresh attempts per 1 minute per IP (default: 30)
REFRESH_RATE_LIMIT=30

# Account lockout: max failed password attempts before locking (default: 5)
MAX_FAILED_ATTEMPTS=5
# Account lockout duration in milliseconds (default: 1800000 = 30 minutes)
ACCOUNT_LOCK_DURATION_MS=1800000

# JWT denylist + refresh token cleanup interval in milliseconds (default: 3600000 = 1 hour)
JWT_CLEANUP_INTERVAL_MS=3600000

# CORS: comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

DB_NAME=./storage/nodejs-api-authentication.db
DIALECT=sqlite

# DB_USER=zz
# DB_PASS=zz
# DB_HOST=localhost
# DIALECT=postgres

HASH_SALT=12

# Base URL used to build links in emails (password reset, confirmation)
APP_URL=http://localhost:4000

# Refresh token expiry (used for reference / documentation; actual expiry is
# hardcoded as 7 days in the auth controller)
# REFRESH_TOKEN_EXPIRES_IN=7d

ADMIN_EMAIL=admin@localhost.test
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
